+	protected function filterDuplicateCardsData(array $cardsData, \SplFileInfo $fileinfo)
+	{
+		$result = [];
+		$seen = [];
+
+		foreach ($cardsData as $cardData) {
+			if (!isset($cardData['code'])) {
+				$result[] = $cardData;
+				continue;
+			}
+
+			$code = (string) $cardData['code'];
+			if (isset($seen[$code]) || isset($this->importedCardCodes[$code])) {
+				$this->output->writeln(
+					"Skipping duplicate card code <info>".$code."</info> in <info>".$fileinfo->getPathname()."</info>"
+				);
+				continue;
+			}
+
+			$seen[$code] = true;
+			$this->importedCardCodes[$code] = true;
+			$result[] = $cardData;
+		}
+
+		return $result;
+	}
